# ============================================================
# Vnansial — environment variables
# Copy to .env and fill in. Live demo: https://vnansial.mukhayyar.my.id/
# ============================================================

# ---- AI provider (any OpenAI-compatible endpoint works) ----
# Default: SumoPod (Indonesian inference provider, free tier available).
# Swap in OpenAI, OpenRouter, Anthropic-compatible proxy, local Ollama, etc.
SUMOPOD_API_KEY=sk-your-key-here
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=qwen3.6-flash

# ---- Privacy: PIN for personal data ----
# Required for /api/me/* endpoints (portfolio, health history) and for
# the AI agent to read/write your SQLite data. Leave empty to run in
# open dev mode (NOT recommended for production).
VNANSIAL_PIN=

# ---- SQLite ----
# Optional override; defaults to ./server/data/vnansial.db
# VNANSIAL_DB_PATH=/var/lib/vnansial/vnansial.db

# ---- Telegram bot (optional) ----
# Get a token from @BotFather and paste here to activate the bot.
# TELEGRAM_BOT_TOKEN=

# ---- Yahoo Finance ----
# Set YAHOO_MOCK=1 for offline/CI fixtures
# YAHOO_MOCK=1

# ---- Server ----
PORT=3001
VNANSIAL_PUBLIC_URL=http://localhost:5173

# ---- Frontend ----
# Leave empty when web + API share an origin. Override only for split deploys.
# VITE_API_URL=http://localhost:3001
